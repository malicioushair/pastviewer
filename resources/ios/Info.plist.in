<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleName</key>
	<string>PastViewer</string>
	<key>CFBundleIdentifier</key>
	<string>@APPLE_APP_REVERSED_DOMAIN@</string>
	<key>CFBundleExecutable</key>
	<string>PastViewer</string>

	<key>CFBundleVersion</key>
	<string>@CMAKE_PROJECT_VERSION_MAJOR@.@CMAKE_PROJECT_VERSION_MINOR@.@CMAKE_PROJECT_VERSION_PATCH@</string>
	<key>CFBundleShortVersionString</key>
	<string>@CMAKE_PROJECT_VERSION_MAJOR@.@CMAKE_PROJECT_VERSION_MINOR@</string>

	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleAllowMixedLocalizations</key>
	<true/>

	<!-- iPhone / iPod: loose PNGs in the app root (AppIcon60x60@2x.png from actool POST_BUILD for Ninja). -->
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconFiles</key>
			<array>
				<string>AppIcon60x60</string>
			</array>
		</dict>
	</dict>
	<!-- iPad -->
	<key>CFBundleIcons~ipad</key>
	<dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconFiles</key>
			<array>
				<string>AppIcon76x76</string>
			</array>
		</dict>
	</dict>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- Injected by Qt CMake from QT_IOS_LAUNCH_SCREEN / default storyboard basename -->
	<key>UILaunchStoryboardName</key>
	<string>@qt_ios_launch_screen_plist_entry@</string>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>PastViewer uses your location to show your position on the map and find historical photos near you. For example, when you walk through a neighborhood, the app highlights archival photos taken at nearby street corners.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>PastViewer uses your location to show your position on the map and find historical photos near you. For example, when you walk through a neighborhood, the app highlights archival photos taken at nearby street corners.</string>
	<key>NSLocationUsageDescription</key>
	<string>PastViewer uses your location to show your position on the map and find historical photos near you. For example, when you walk through a neighborhood, the app highlights archival photos taken at nearby street corners.</string>

	<key>NSCameraUsageDescription</key>
	<string>PastViewer uses your camera to display a live view next to a historical photo so you can compare then and now. For example, when you tap "Recreate this view," the camera helps you align today's scene with the archival image.</string>

	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>PastViewer saves then-and-now comparison images to your photo library so you can keep and share them. For example, when you capture a recreation in Camera Mode, the combined image is saved to Photos.</string>

	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
</dict>
</plist>
